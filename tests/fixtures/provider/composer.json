{
    "name": "acme/assets-provider",
    "version": "1.0.0",
    "type": "library",
    "extra": {
        "composer-assets": {
            "file-mapping": {
                "web/.htaccess": { "path": "assets/htaccess", "mode": "0640" },
                "web/robots.txt": { "path": "assets/robots.txt", "overwrite": false },
                "web/.htaccess-extra": { "append": "assets/htaccess-extra", "force-append": true },
                "web/skip-me.txt": false,
                "package.json": { "merge": "assets/package-fragment.json", "force-merge": true },
                ".tugboat/config.yml": { "merge": "assets/tugboat-overlay.yml", "force-merge": true },
                ".circleci/config.yml": { "path": "assets/circleci.yml", "gitignore": false },
                "web/override-me.txt": "assets/cond/present.txt",
                ".github/": "assets/github/",
                "web/cond-present.txt": { "path": "assets/cond/present.txt", "if": { "package": "acme/assets-provider" } },
                "web/cond-absent.txt": { "path": "assets/cond/present.txt", "if": { "package": "nope/missing" } },
                "web/cond-variant.txt": [
                    { "path": "assets/cond/new.txt", "if": { "php": ">=8.0" } },
                    { "path": "assets/cond/old.txt" }
                ]
            },
            "conditional": [
                {
                    "if": { "package": "acme/assets-provider" },
                    "file-mapping": { "web/group-present.txt": "assets/cond/present.txt" }
                },
                {
                    "if": { "package": "nope/missing" },
                    "file-mapping": { "web/group-absent.txt": "assets/cond/present.txt" }
                }
            ]
        }
    }
}
